# =============================================================
# App Selección Web — Variables de entorno
# Copiar este archivo como .env.local y completar los valores
# =============================================================

# --- Supabase ---
# Obtener desde: Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo para Server Actions que necesitan bypass de RLS (candidatos no autenticados)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- App ---
# URL pública de la app (para generar links de evaluación)
NEXT_PUBLIC_APP_URL=http://localhost:3000
